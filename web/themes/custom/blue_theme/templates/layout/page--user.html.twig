            </svg>
            <span class="visually-hidden">Logo</span>
          </a>
          {{ page.content_above }}
          {{ page.content }}
        </main>
        <aside class="col-md-4 hire__logos">
          {% if config_page_info_list %}
          <div class="list">
            <div class="list__header">
              <div class="list__title">
                {{ config_page_info_list.title }}
              </div>
              <div class="list__description">
                {{ config_page_info_list.description }}
              </div>
            </div>
          </div>
          {% endif %}
          <span class="bg">
            <span class="circles"></span>
          </span>
        </aside>
      </div>
    </div>
  </div>
</div>
